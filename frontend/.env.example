# STAR-FARM Frontend Configuration
# Copy this file to .env and adjust as needed.
# NEVER commit the actual .env file with real credentials to version control.

# Base URL for the backend API (no trailing slash)
VITE_API_BASE=http://localhost:8000/api

# Maximum CSV file size the client will accept before uploading (in bytes, default 10 MB)
VITE_MAX_UPLOAD_BYTES=10485760
